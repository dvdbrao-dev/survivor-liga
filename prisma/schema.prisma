generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OperationStage {
  NEW
  IN_PROGRESS
  PROPOSAL_SENT
  PENDING_RESPONSE
  WON
  LOST
}

enum SettlementStatus {
  PENDING
  PARTIAL
  PAID
}

enum MovementType {
  INCOME
  EXPENSE
  RECEIVABLE
  PAYABLE
}

model Client {
  id         String      @id @default(cuid())
  name       String
  industry   String
  operations Operation[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Collaborator {
  id         String      @id @default(cuid())
  name       String
  role       String
  operations Operation[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Operation {
  id                      String           @id @default(cuid())
  title                   String
  operationType           String
  stage                   OperationStage   @default(NEW)
  grossCommission         Decimal          @db.Decimal(12, 2)
  collaboratorCommission  Decimal          @db.Decimal(12, 2)
  companyMargin           Decimal          @db.Decimal(12, 2)
  collectionStatus        SettlementStatus @default(PENDING)
  paymentStatus           SettlementStatus @default(PENDING)
  nextAction              String
  nextActionDate          DateTime
  clientId                String
  collaboratorId          String
  client                  Client           @relation(fields: [clientId], references: [id])
  collaborator            Collaborator     @relation(fields: [collaboratorId], references: [id])
  cashMovements           CashMovement[]
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@index([stage])
  @@index([nextActionDate])
}

model CashMovement {
  id          String       @id @default(cuid())
  type        MovementType
  description String
  amount      Decimal      @db.Decimal(12, 2)
  dueDate     DateTime
  isSettled   Boolean      @default(false)
  operationId String?
  operation   Operation?   @relation(fields: [operationId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([type, dueDate])
}
